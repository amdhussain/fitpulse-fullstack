# ============================================
# FitPulse Backend - Environment Configuration
# ============================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ─── Server ─────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ─── Authentication ─────────────────────────
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d
COOKIE_SECRET=your-cookie-secret-here
BETTER_AUTH_SECRET=your-better-auth-secret-here
BETTER_AUTH_URL=http://localhost:5000/api/auth

# ─── Database ───────────────────────────────
# DATABASE_URL=mysql://root:password@localhost:3306/fitpulse
# DATABASE_URL=mysql://root:Admin@12345@localhost:3306/fitpulse_dev

#  mysql://2KMsKDzgeYKmCpS.root:uKee8Z11EvXAWjei@gateway01.ap-southeast-1.prod.aws.tidbcloud.com:4000/sys?sslaccept=strict

DATABASE_URL="mysql://2KMsKDzgeYKmCpS.root:uKee8Z11EvXAWjei@gateway01.ap-southeast-1.prod.aws.tidbcloud.com:4000/fitpulse_db?sslaccept=strict"
PS C:\Users\Dell Xps\fitness-booking-platform> 

# ─── Cloudinary ─────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Stripe ─────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# ─── Rate Limiting ──────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Cookie ─────────────────────────────────
COOKIE_MAX_AGE=86400000
